NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Local/test-only: direct Postgres admin connection used by the Vitest DB suites. Not a hosted/prod
# variable — for local `supabase start` its value is the well-known default and lives in .env.local.
SUPABASE_DB_URL=
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=
# Cloudflare Turnstile. Sitekey is public (NEXT_PUBLIC_); secret is server-only — never NEXT_PUBLIC_.
# Local/dev uses Cloudflare's published DUMMY test keys (D-1.04-8); real keys land in 1.07/2.05.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Server-only pepper for the SHA-256 IP hash used by the order rate limit (D-1.04-7). Never NEXT_PUBLIC_,
# never committed. A random high-entropy string; rotating it just resets the rate-limit window.
ORDER_IP_HASH_PEPPER=
